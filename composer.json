{
    "name": "loucov/laravel-moncash-api",
    "type": "library",
    "description": "Laravel package to integrate the Digicel Haiti MonCash payment gateway (payments, transfers, transaction lookup).",
    "keywords": [
        "LouCov",
        "laravel",
        "moncash",
        "digicel",
        "haiti",
        "payment",
        "gateway"
    ],
    "homepage": "https://github.com/LouCov/laravel-moncash-api",
    "license": "MIT",
    "authors": [
        {
            "name": "LouCov",
            "email": "covilloocko@gmail.com",
            "homepage": "https://github.com/loucov",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "LouCov\\LaravelMonCashApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LouCov\\LaravelMonCashApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "main-dev"
        },
        "laravel": {
            "providers": [
                "LouCov\\LaravelMonCashApi\\MoncashServiceProvider"
            ],
            "aliases": {
                "MoncashApi": "LouCov\\LaravelMonCashApi\\Facades\\MoncashApi"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
